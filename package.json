{
  "name": "portfolio",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --filter=web run dev",
    "build": "bun --filter='*' run build",
    "build:web": "bun --filter=web run build",
    "check-types": "bun --filter='*' run check-types",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --check",
    "format:fix": "oxfmt",
    "check": "oxlint && oxfmt --check"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "oxlint --fix",
      "oxfmt"
    ],
    "*.{json,jsonc,md,mdx,css,scss,yaml,yml,html,toml}": [
      "oxfmt"
    ]
  },
  "packageManager": "bun@1.2.19"
}
