{
  "name": "portfolio",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --filter=web run dev",
    "build": "bun --filter='*' run build",
    "build:web": "bun --filter=web run build",
    "check-types": "bun --filter='*' run check-types",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "format": "vp fmt --check",
    "format:fix": "vp fmt --write",
    "check": "vp check"
  },
  "devDependencies": {
    "vite-plus": "catalog:"
  },
  "overrides": {
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "packageManager": "bun@1.2.19",
  "catalog": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest",
    "vite-plus": "latest"
  }
}
