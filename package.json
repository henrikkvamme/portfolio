{
  "name": "portfolio",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --check",
    "format:fix": "oxfmt",
    "check": "oxlint && oxfmt --check"
  },
  "dependencies": {
    "@radix-ui/react-switch": "^1.2.6",
    "@react-three/fiber": "^9.3.0",
    "@types/three": "^0.178.1",
    "mapbox-gl": "^3.14.0",
    "next": "15.3.8",
    "react-map-gl": "^8.0.4",
    "three": "^0.179.1"
  },
  "devDependencies": {
    "@types/react-map-gl": "^6.1.7",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "turbo": "^2.5.4"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "oxlint --fix",
      "oxfmt"
    ],
    "*.{json,jsonc,md,mdx,css,scss,yaml,yml,html,toml}": [
      "oxfmt"
    ]
  },
  "packageManager": "bun@1.2.19"
}
